#!/usr/bin/env node

/**
 * Legacy entrypoint (node-only).
 *
 * This file is intentionally a thin wrapper so it can run without `tsx`.
 * The supported CLI is `qtests-generate` (and `qtests-ts-generate` via npm bin),
 * implemented in `bin/qtests-generate.mjs`.
 */

(async () => {
  await import('./qtests-generate.mjs');
})().catch((error) => {
  const message = error && (error.stack || error.message) ? (error.stack || error.message) : String(error);
  process.stderr.write(message + '\n');
  process.exit(1);
});

